# Server
PORT=3000
DAY_COUNT=7
CACHE_TTL_MS=300000
REFRESH_INTERVAL_MS=300000
FRONTEND_POLL_MS=60000
SETUP_TOKEN=bitte-langen-zufaelligen-wert-setzen

# Planday OAuth/API
PLANDAY_API_BASE_URL=https://openapi.planday.com
PLANDAY_AUTHORIZE_URL=https://id.planday.com/connect/authorize
PLANDAY_TOKEN_URL=https://id.planday.com/connect/token
PLANDAY_CLIENT_ID=
PLANDAY_CLIENT_SECRET=
PLANDAY_REDIRECT_URI=http://localhost:3000/setup/planday/callback
PLANDAY_SCOPES=openid offline_access shift:read
PLANDAY_TOKEN_FILE=./data/planday-token.json

# Optional: nur verwenden, wenn bereits ein Refresh Token vorhanden ist.
PLANDAY_REFRESH_TOKEN=

# Lesender Scheduling-Shifts-Endpunkt. Bei Bedarf an eure freigeschalteten API-Endpunkte anpassen.
PLANDAY_SHIFTS_PATH=/scheduling/v1.0/shifts
PLANDAY_SHIFTS_METHOD=GET
PLANDAY_SHIFTS_LIMIT=300
# Optional. Fuer den GET-Endpunkt leer lassen, wenn alle Schichten geladen werden sollen.
PLANDAY_SHIFT_STATUS=

# Optional: Regeln, wenn Planday Einzel-Schichten liefert und nur die Team-Zuordnung je Schichtart angezeigt werden soll.
# Sobald Regeln gesetzt sind, werden nur passende Schichten angezeigt.
# Beispiel:
# Regeln koennen shiftTypeIds, categoryIds, employeeGroupIds oder departmentIds enthalten.
# PLANDAY_PERIOD_RULES=[{"period":"early","shiftTypeIds":[205105]},{"period":"late","categoryIds":[15948]},{"period":"night","categoryIds":[15947]}]
PLANDAY_PERIOD_RULES=

# Setup-Endpunkte fuer IDs. Bei Bedarf an eure freigeschalteten API-Endpunkte anpassen.
PLANDAY_DEPARTMENTS_PATH=/hr/v1/Departments
PLANDAY_SHIFT_GROUPS_PATH=/hr/v1/EmployeeGroups

# Optional: nur bestimmte Departments abrufen, kommasepariert.
PLANDAY_DEPARTMENT_IDS=

# Erlaubte Schichtgruppen. Nur diese Namen werden an das Frontend geliefert.
# Format 1: JSON
# PLANDAY_SHIFT_GROUPS={"101":"Gruppe A","102":"Gruppe B","103":"Gruppe C","104":"Gruppe D"}
#
# Format 2: Semikolon-Liste
PLANDAY_SHIFT_GROUPS=101:Gruppe A;102:Gruppe B;103:Gruppe C;104:Gruppe D

# Optional: Team-Erkennung ueber Schichtfuehrer und Vertreter.
# Diese Employee-IDs werden nur serverseitig verarbeitet und nie ans Frontend ausgeliefert.
# JSON wegen der # in Farbwerten quoten.
# PLANDAY_TEAM_RULES='[{"team":"Team A","color":"#FA7E01","leaderEmployeeIds":[1001],"substituteEmployeeIds":[2001]}]'
PLANDAY_TEAM_RULES=
